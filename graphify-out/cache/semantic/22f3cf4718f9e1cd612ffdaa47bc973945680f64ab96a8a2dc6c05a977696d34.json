{"nodes": [{"id": "plans_2026_06_08_details_rail_progressive_disclosure_doc", "label": "Plan: Details Rail Progressive Disclosure", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-08-details-rail-progressive-disclosure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_08_details_rail_progressive_disclosure_railfields_registry", "label": "railFields descriptor registry", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-08-details-rail-progressive-disclosure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A pure field-descriptor registry is the single source of truth for each field's label, pinned-ness, populated-ness, canonical ordering, and clear action; pinned fields (status/labels/assignees) always render and never appear in the Add menu."}, {"id": "plans_2026_06_08_details_rail_progressive_disclosure_userailfields", "label": "useRailFields composable", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-08-details-rail-progressive-disclosure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Owns transient per-session revealed/removed sets (never persisted; cleared on save/cancel) and derives visibleKeys + hiddenFields; lives in the parent IssueDetail because that's where the draft lives, keeping the rail child mutation-free."}, {"id": "plans_2026_06_08_details_rail_progressive_disclosure_addfieldmenu", "label": "AddFieldMenu component", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-08-details-rail-progressive-disclosure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_08_details_rail_progressive_disclosure_progressive_disclosure", "label": "Rail progressive disclosure", "