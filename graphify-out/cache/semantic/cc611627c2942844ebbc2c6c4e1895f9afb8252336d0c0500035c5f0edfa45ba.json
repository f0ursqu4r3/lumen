{"nodes": [{"id": "plans_2026_06_05_issue_multiselect_plan2_combined_window_plan", "label": "Issue Multi-Select Plan 2: Combined Multi-Issue Window", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-05-issue-multiselect-plan2-combined-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_05_issue_multiselect_plan2_combined_window_multiissuewindow", "label": "MultiIssueWindow (pager over IssueDetail)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-issue-multiselect-plan2-combined-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A combined native window showing one issue at a time behind a \u2039 X of N \u203a pager, each page fully editable: renders IssueDetail with embedded=true so IssueDetail emits update:dirty for the pager's discard-guard while MultiIssueWindow owns title, pager, and chrome."}, {"id": "plans_2026_06_05_issue_multiselect_plan2_combined_window_issueswindowurl", "label": "issuesWindowUrl + openIssuesWindow RPC", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-issue-multiselect-plan2-combined-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A host RPC openIssuesWindow({fullPath, iids}) spawns a fresh BrowserWindow (no dedupe) at a hash route carrying comma-joined iids (order preserved = pager order) and ?window=1; built by issuesWindowUrl with the same base rules as issueWindowUrl. Later superseded by route builders when fragments proved unloadable over views://."}], "edges": [{"source": "plans_2026_06_05_issue_multiselect_plan2_combined_window_plan", "target": "plans_2026_06_05_issue_multiselect_plan1_selection_bulk_plan", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/pl