{"nodes": [{"id": "specs_2026_06_02_issue_editing_filtering_tags_design_doc", "label": "Spec: Issue Editing, Filtering & Editable Tags", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_02_issue_editing_filtering_tags_design_issueedit_lib", "label": "issueEdit pure lib (IssueDraft, diffIssueEdit)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure draft/dirty/diff model: label diff computes add/removeLabelIds from id-set delta, state diff maps to CLOSE/REOPEN events, assignee diff is order-insensitive and emits the full next list because setAssignees uses REPLACE semantics."}, {"id": "specs_2026_06_02_issue_editing_filtering_tags_design_useissuedraft", "label": "useIssueDraft buffered-edit composable", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Holds a reactive draft seeded from the issue and re-syncs from server refetches only while the buffer is clean \u2014 never clobbers in-flight edits. save() runs diffIssueEdit and fires the update/assignee mutations; Cancel reverts; tags are just a buffered field."}, {"id": "specs_2026_06_02_issue_editing_filtering_tags_design_useissuefilters", "label": "useIssueFilters URL-persisted filters", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single source of truth for state/search/labels/assignee/author serialized to the route query (search debounced), shared by list and board so both views filter identically; URL persistence matches the ?issue= drawer pattern."}, {"id": "specs_2026_06_02_issue_editing_filtering_tags_design_issuefilterpanel", "label": "IssueFilterPanel", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_02_issue_editing_filtering_tags_design_confirmdialog", "label": "ConfirmDialog dirty guard", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Confirm-before-discard built on shadcn-vue alert-dialog, resolving a promise; applied via onBeforeRouteLeave on the full page and via the drawer close/iid-switch handlers, with dirty state surfaced from the embedded detail to its host."}], "edges": [{"source": "specs_2026_06_02_assignee_editor_design_assigneeeditor", "target": "specs_2026_06_02_issue_editing_filtering_tags_design_useissuedraft", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_02_issue_editing_filtering_tags_design_doc", "target": "specs_2026_06_02_issue_editing_filtering_tags_design_issueedit_lib", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-issue-editing-filtering-tags-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_02_issue_editing_filtering_tags_design_doc", "target": "specs_2026_06_02_issue_editing_filtering_tags_design_useissuedraft", "relation":