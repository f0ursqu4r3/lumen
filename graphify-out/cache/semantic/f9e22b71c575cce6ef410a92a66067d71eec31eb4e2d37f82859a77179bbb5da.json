{"nodes": [{"id": "specs_2026_06_04_electrobun_port_design", "label": "Electrobun Port Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_04_electrobun_port_design_bun_rpc_transport", "label": "Bun RPC GitLab Transport", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replace exactly one thing \u2014 the Vite token-injecting dev-server proxy \u2014 so the Vue app changes as little as possible. Webview \u2192 typed RPC \u2192 Bun does the upstream fetch holding the token; the token never enters the webview. graphql-request kept with a custom fetch so no query call-site changes."}, {"id": "specs_2026_06_04_electrobun_port_design_usegitlabasset", "label": "useGitlabAsset Blob-URL Asset Loading", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RPC \u2192 blob URL chosen because it uses only confirmed Electrobun APIs; a custom-scheme handler is a later simplification if the API proves clean. Memoized per path with revoke on unmount."}, {"id": "specs_2026_06_04_electrobun_port_design_persisted_query_cache", "label": "Disk-Persisted Query Cache", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "localStorage persister via @tanstack/query-persist-client-core: native webview localStorage is disk-backed per app so cache survives restart and renders instantly offline. buster keyed on gitlabUrl + token fingerprint so switching instances or rotating the token invalidates stale cache."}], "edges": [{"source": "specs_2026_06_04_electrobun_port_design", "target": "specs_2026_06_04_electrobun_port_design_bun_rpc_transport", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_electrobun_port_design", "target": "specs_2026_06_04_electrobun_port_design_usegitlabasset", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_electrobun_port_design", "target": "specs_2026_06_04_electrobun_port_design_persisted_query_cache", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_electrobun_port_design_usegitlabasset", "target": "specs_2026_06_04_electrobun_port_design_bun_rpc_transport", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_electrobun_port_design", "target": "specs_2026_06_03_issue_media_viewer_design_media_trigger", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-electrobun-port-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_electrobun_port_design_usegitlabasset", "target": "specs_2026_06_03_issue_media_viewer_design_mediaviewer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04