{"nodes": [{"id": "specs_2026_06_09_my_work_dashboard_design", "label": "My Work Dashboard Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_09_my_work_dashboard_design_mywork_dashboard", "label": "My Work Dashboard View", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Opening the app lands on a cross-project home answering 'what needs me right now': assigned issues, assigned MRs, review-requested MRs as three lanes. Project Picker moves to /projects with route name 'projects' preserved so every existing push keeps working unchanged. The first:25 query cap is the view \u2014 no pagination in v1."}, {"id": "specs_2026_06_09_my_work_dashboard_design_dashboardlane", "label": "DashboardLane Component", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Per-lane independence: each lane binds its own query's isLoading/error/data, so one lane failing or loading never blanks the others; inbox-zero still shows the three headers so the page doesn't look broken."}, {"id": "specs_2026_06_09_my_work_dashboard_design_parseissuepath", "label": "parseIssuePath Helper", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The root issues query's Issue type has no project object (only webPath/webUrl/projectId), so fullPath+iid are parsed from webPath with nested-group support; on parse failure the row falls back to the external webUrl."}], "edges": [{"source": "specs_2026_06_09_my_work_dashboard_design", "target": "specs_2026_06_09_my_work_dashboard_design_mywork_dashboard", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_my_work_dashboard_design", "target": "specs_2026_06_09_my_work_dashboard_design_dashboardlane", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_my_work_dashboard_design", "target": "specs_2026_06_09_my_work_dashboard_design_parseissuepath", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_my_work_dashboard_design_mywork_dashboard", "target": "specs_2026_06_09_my_work_dashboard_design_dashboardlane", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_my_work_dashboard_design_mywork_dashboard", "target": "specs_2026_06_09_my_work_dashboard_design_parseissuepath", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_my_work_dashboard_design", "target": "specs_2026_06_08_merge_requests_browse_triage_design", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-my-work-dashboard-design.md", 