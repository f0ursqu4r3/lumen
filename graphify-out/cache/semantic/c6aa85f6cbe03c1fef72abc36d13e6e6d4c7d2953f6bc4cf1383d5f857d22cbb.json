{"nodes": [{"id": "specs_2026_06_03_issue_media_viewer_design", "label": "Issue Media Viewer Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_03_issue_media_viewer_design_classifyupload", "label": "classifyUpload Media Classifier", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GitLab embeds every uploaded attachment with image Markdown syntax regardless of type, so a .mp4 upload shows as a broken image; classification by extension fixes this \u2014 video/audio render native elements, non-media uploads render a download chip."}, {"id": "specs_2026_06_03_issue_media_viewer_design_extractmedia", "label": "extractMedia Token Extraction", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runs the same Marked instance + gitlabImage tokenizer as rendering; rendering and extraction share classifyUpload + rewriteUploadSrc so they never drift."}, {"id": "specs_2026_06_03_issue_media_viewer_design_mediaviewer", "label": "MediaViewer Fullscreen Lightbox", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Manual gallery (no auto-advance); audio and file chips are inline-only since audio has nothing to show and files just download. Source attribution distinguishes description vs comment media."}, {"id": "specs_2026_06_03_issue_media_viewer_design_media_trigger", "label": "data-media-src Delegated Trigger Pattern", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "data-media-src carries the rewritten proxy URL so viewer and inline element load the identical resource. Videos keep inline controls (body click = play); a hover expand overlay carries the trigger so play isn't hijacked \u2014 one delegated click code path for images and videos."}], "edges": [{"source": "specs_2026_06_03_issue_media_viewer_design", "target": "specs_2026_06_03_issue_media_viewer_design_classifyupload", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design", "target": "specs_2026_06_03_issue_media_viewer_design_extractmedia", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design", "target": "specs_2026_06_03_issue_media_viewer_design_mediaviewer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design", "target": "specs_2026_06_03_issue_media_viewer_design_media_trigger", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design_extractmedia", "target": "specs_2026_06_03_issue_media_viewer_design_classifyupload", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design_mediaviewer", "target": "specs_2026_06_03_issue_media_viewer_design_extractmedia", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_03_issue_media_viewer_design_media_trigger", "target": "specs_2026_06_03_issue_media_viewer_design_mediaviewer", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-03-issue-media-viewer-design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}