{"nodes": [{"id": "specs_2026_06_06_reorder_interactions_polish_design", "label": "Reorder Interactions Polish Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_06_reorder_interactions_polish_design_pointer_reorder", "label": "Pointer-Events Reorder Mechanism", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Native HTML5 DnD structurally caps ghost/indicator quality \u2014 a static drag image, no live insertion line, no edge auto-scroll \u2014 so the reorder interaction is rewritten on pointer events for a Linear/Notion-class feel (cursor-following chip, live insertion bar, lift/settle, edge auto-scroll). Card drag-and-drop stays native and untouched; all motion respects prefers-reduced-motion."}, {"id": "specs_2026_06_06_reorder_interactions_polish_design_insertionindexfor", "label": "insertionIndexFor Pure Geometry", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All inputs are plain data so it unit-tests with synthetic DOMRects on both axes; items are discovered via data-reorder-key attributes so the composable never holds Vue refs."}, {"id": "specs_2026_06_06_reorder_interactions_polish_design_reordertoindex", "label": "reorderToIndex Commit Helper", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Index-based commit replaces the old over-key-based reorderKeys, which is removed along with its tests since the pointer flow leaves it with no caller."}], "edges": [{"source": "specs_2026_06_06_reorder_interactions_polish_design", "target": "specs_2026_06_06_reorder_interactions_polish_design_pointer_reorder", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_interactions_polish_design", "target": "specs_2026_06_06_reorder_interactions_polish_design_insertionindexfor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_interactions_polish_design", "target": "specs_2026_06_06_reorder_interactions_polish_design_reordertoindex", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_interactions_polish_design_pointer_reorder", "target": "specs_2026_06_06_reorder_interactions_polish_design_insertionindexfor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_interactions_polish_design_pointer_reorder", "target": "specs_2026_06_06_reorder_interactions_polish_design_reordertoindex", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-interactions-polish-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_intera