{"nodes": [{"id": "specs_2026_06_06_reorder_groups_columns_design", "label": "Reorder Groups & Columns Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_06_reorder_groups_columns_design_usegrouporder", "label": "useGroupOrder Persistence Store", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Groups/columns are synthetic \u2014 built client-side from labels and work-item statuses; GitLab has no API to persist an order for them, so custom order is a local per-project presentation preference. Indexing by the dimension string makes the order shared across list and board for free. Not captured by Saved Views to avoid coupling and snapshot bloat."}, {"id": "specs_2026_06_06_reorder_groups_columns_design_applyorder", "label": "applyOrder Pure Reorder Pass", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stable reordering: groups in the stored order come first, unknown groups keep default relative order and append after, stale keys are ignored \u2014 so new columns land at the end and deleted columns are harmless without special-casing '__none'."}, {"id": "specs_2026_06_06_reorder_groups_columns_design_usegroupreorder", "label": "useGroupReorder Drag Interaction (HTML5 DnD)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Native HTML5 drag from a dedicated header grip with a custom dataTransfer type (application/x-lumen-group) to stay distinct from card drags; the codebase hand-rolls DnD throughout, so no new drag library. Card DnD handlers already early-return when no card is in hand, so there is no collision."}], "edges": [{"source": "specs_2026_06_06_reorder_groups_columns_design", "target": "specs_2026_06_06_reorder_groups_columns_design_usegrouporder", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_groups_columns_design", "target": "specs_2026_06_06_reorder_groups_columns_design_applyorder", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_groups_columns_design", "target": "specs_2026_06_06_reorder_groups_columns_design_usegroupreorder", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_groups_columns_design_usegroupreorder", "target": "specs_2026_06_06_reorder_groups_columns_design_usegrouporder", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_06_reorder_groups_columns_design_usegrouporder", "target": "specs_2026_06_06_reorder_groups_columns_design_applyorder", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-06-reorder-groups-columns-design.md", "source_location": null, "weight":