{"nodes": [{"id": "plans_2026_06_06_server_unavailable_vs_token_invalid_doc", "label": "Plan: Server-Unavailable vs Token-Invalid", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-06-server-unavailable-vs-token-invalid.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_06_server_unavailable_vs_token_invalid_unavailable_kind", "label": "unavailable error kind + 503 sentinel", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-server-unavailable-vs-token-invalid.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The host catches fetch transport throws and returns a 503 sentinel, unifying 'server threw' and 'server returned 5xx' into one unavailable path so normalizeError/httpError need only a single >=500 rule \u2014 a down server never triggers a re-auth prompt."}, {"id": "plans_2026_06_06_server_unavailable_vs_token_invalid_auth_wins_invariant", "label": "Auth-wins escalation invariant", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-06-06-server-unavailable-vs-token-invalid.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "expired and unavailable are mutually exclusive and auth always wins: markSessionExpired clears the banner, markServerUnavailable is a no-op once expired \u2014 a token problem must never be downgraded to a transient banner."}, {"id": "plans_2026_06_06_server_unavailable_vs_token_invalid_useserverrecovery", "label": "useServerRecovery backoff poll", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-server-unavailable-vs-token-invalid.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "2s \u2192 5s \u2192 15s capped backoff probing the cheap currentUser query directly 