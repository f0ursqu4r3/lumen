{"nodes": [{"id": "plans_2026_06_02_comments_grouped_labels_scratchpad_plan", "label": "Comments-in-Save, Grouped Label Menus, Collapsible Scratchpad Plan", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_02_comments_grouped_labels_scratchpad_labelgroups", "label": "labelGroups (groupLabelsByScope + toggleScoped)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure, framework-free scope grouping (preferred scopes first, unscoped Other last) plus toggleScoped: selecting a scoped value removes any other selected title in the same scope (scoped-label exclusivity), while unscoped labels are plain toggles. Rendered by a shared LabelGroupMenu consumed by LabelPicker (exclusive) and IssueFilterPanel (plain multi)."}, {"id": "plans_2026_06_02_comments_grouped_labels_scratchpad_comment_in_draft", "label": "Comment Folded into the Issue Draft", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The pending comment becomes a field of the useIssueDraft orchestration (not the pure IssueDraft): it marks the draft dirty, posts on Save, clears only on full success, and a failed note post leaves comment + dirty intact so the user can retry or cancel. The standalone Comment button is removed."}, {"id": "plans_2026_06_02_comments_grouped_labels_scratchpad_collapsible_scratchpad", "label": "Collapsible Scratchpad with Content Marker", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Collapsed by default with a dot marker when it has content; open state persisted per issue (lumen:scratchpad-open:fullPath#iid) mirroring the note's per-issue keying; v-show keeps the textarea in the DOM so existing tests still pass."}], "edges": [{"source": "plans_2026_06_02_comments_grouped_labels_scratchpad_plan", "target": "plans_2026_06_02_comments_grouped_labels_scratchpad_labelgroups", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_02_comments_grouped_labels_scratchpad_plan", "target": "plans_2026_06_02_comments_grouped_labels_scratchpad_comment_in_draft", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_02_comments_grouped_labels_scratchpad_plan", "target": "plans_2026_06_02_comments_grouped_labels_scratchpad_collapsible_scratchpad", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_02_comments_grouped_labels_scratchpad_comment_in_draft", "target": "plans_2026_06_02_issue_editing_filtering_tags_useissuedraft", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-02-comments-grouped-labels-scratchpad.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_02_comments_grouped_labels_scratchpad_collapsible_scratchpad", "target": "plans_2026_06_01_scratchpad_usescratchpad", "relation": "references", "con