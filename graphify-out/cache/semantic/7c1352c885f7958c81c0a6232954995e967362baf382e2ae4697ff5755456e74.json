{"nodes": [{"id": "plans_2026_06_09_unified_app_shell_phase3_doc", "label": "Plan: Unified App Shell Phase 3", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-09-unified-app-shell-phase3.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_09_unified_app_shell_phase3_apptopbar_detail_branch", "label": "AppTopBar detail branch", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-09-unified-app-shell-phase3.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Back + breadcrumb + #iid for issue/merge-request routes; the #app-topbar-slot carries the view's teleported actions."}, {"id": "plans_2026_06_09_unified_app_shell_phase3_viewcontainer_bare", "label": "ViewContainer 'bare' width", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-09-unified-app-shell-phase3.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A passthrough (no max-width/centering/padding) so a view that sometimes renders inside an existing container (popped-out window's main, the drawer) can use the same ViewContainer wrapper unconditionally."}, {"id": "plans_2026_06_09_unified_app_shell_phase3_issuedetail_three_modes", "label": "IssueDetail/IssueMasthead three modes", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-06-09-unified-app-shell-phase3.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Full-page main window (shell present \u2192 masthead teleports actions, breadcrumb from shell), popped-out native window (?window=1 \u2192 no shell, masthead renders its own header), and embedded drawer (renders inline, no teleport). The teleport happens only in the !embedded && !windowed branch."}], "edges": [{"source": "plans_2026_06_09