{"nodes": [{"id": "plans_2026_06_06_reorder_interactions_polish_doc", "label": "Plan: Reorder Interactions & Ghost Polish", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-06-reorder-interactions-polish.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_06_reorder_interactions_polish_reordertoindex", "label": "reorderToIndex pure helper", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-reorder-interactions-polish.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The pointer-driven reorder thinks in terms of a landing index rather than an over-key, so reorderToIndex replaces (and retires) reorderKeys."}, {"id": "plans_2026_06_06_reorder_interactions_polish_insertionindexfor", "label": "insertionIndexFor reorder geometry", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-reorder-interactions-polish.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure geometry turning cursor position + item rects into landing index, insertion-bar offset (in container content coordinates so the bar tracks scrolled content), and a no-op flag; computeInsertion is the thin DOM wrapper."}, {"id": "plans_2026_06_06_reorder_interactions_polish_reorderghost", "label": "ReorderGhost cursor chip", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-reorder-interactions-polish.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_06_reorder_interactions_polish_pointer_reorder", "label": "Pointer-driven useGroupReorder rewrite", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-06-reorder-interactions-polish.md", "source_location": null, "source_url": null, "captured_at": null, "autho