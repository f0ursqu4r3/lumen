{"nodes": [{"id": "specs_2026_06_05_session_expiry_recovery_design", "label": "Session-Expiry Recovery Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_05_session_expiry_recovery_design_usesession", "label": "useSession installAuthWatch", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A single watcher subscribed to both the vue-query query and mutation caches flips sessionState.expired on any GitLabError kind 'auth' \u2014 global detection with no per-view changes. The host is stateless w.r.t. the token (loadConfig reads fresh from disk per RPC), so no host relaunch is needed: the original 'restart the backend' framing was a misread of the architecture."}, {"id": "specs_2026_06_05_session_expiry_recovery_design_sessionexpiredoverlay", "label": "SessionExpiredOverlay", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Non-dismissable full-screen blocker \u2014 the only exits are a successful reconnect or an explicit disconnect; reuses useGitlabConnect for the in-place token re-entry."}, {"id": "specs_2026_06_05_session_expiry_recovery_design_reload_recovery", "label": "Recovery via Full Webview Reload", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Full reload chosen over in-place invalidateQueries (edge cases with queries stuck in error) and over redirecting to ConnectView (framed as onboarding, loses location). The recovery probe goes through rpc.gitlabGraphql directly, bypassing vue-query, so a 401 while testing a fresh token never reaches the cache watcher \u2014 no suppression flag needed, the separation is structural."}], "edges": [{"source": "specs_2026_06_05_session_expiry_recovery_design", "target": "specs_2026_06_05_session_expiry_recovery_design_usesession", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_session_expiry_recovery_design", "target": "specs_2026_06_05_session_expiry_recovery_design_sessionexpiredoverlay", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_session_expiry_recovery_design", "target": "specs_2026_06_05_session_expiry_recovery_design_reload_recovery", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_session_expiry_recovery_design_sessionexpiredoverlay", "target": "specs_2026_06_05_session_expiry_recovery_design_usesession", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recovery-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_session_expiry_recovery_design_reload_recovery", "target": "specs_2026_06_05_session_expiry_recovery_design_usesession", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-session-expiry-recov