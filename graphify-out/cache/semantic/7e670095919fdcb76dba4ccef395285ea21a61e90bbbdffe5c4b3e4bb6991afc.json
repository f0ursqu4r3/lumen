{"nodes": [{"id": "plans_2026_06_02_issue_editing_filtering_tags_plan", "label": "Issue Editing, Filtering & Editable Tags Plan", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-02-issue-editing-filtering-tags.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_02_issue_editing_filtering_tags_useissuedraft", "label": "useIssueDraft (buffered Save/Cancel edit)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-issue-editing-filtering-tags.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure edit logic in lib/issueEdit.ts; the composable buffers changes and orchestrates only the mutations the diff requires on Save. The draft re-syncs from the server only while clean, so a background refetch never clobbers in-flight edits."}, {"id": "plans_2026_06_02_issue_editing_filtering_tags_useissuefilters", "label": "useIssueFilters (URL-persisted filter state)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-issue-editing-filtering-tags.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Filter state round-trips to the route query and drives the shared useIssues query for list and board; adds author and assigneeWildcardId NONE (the Unassigned sentinel) mappings."}, {"id": "plans_2026_06_02_issue_editing_filtering_tags_useconfirm", "label": "useConfirm (promise-based confirm singleton)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-02-issue-editing-filtering-tags.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A promise-based confirm singleton plus a ConfirmDialog mounted once in App backs the dirty-guard on unsaved edits; later reused as the pattern template for the settings dialog and b