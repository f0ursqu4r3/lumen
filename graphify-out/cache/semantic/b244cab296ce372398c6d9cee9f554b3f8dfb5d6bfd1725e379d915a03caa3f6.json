{"nodes": [{"id": "specs_2026_06_01_lumen_design_doc", "label": "Spec: Lumen Design", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_01_lumen_design_lumen_app", "label": "Lumen \u2014 personal GitLab issue tracker", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single-user, locally-run SPA over a self-hosted GitLab; GitLab remains the single source of truth \u2014 no local database, no deployed backend. Non-goals: multi-user auth, offline support, data mirroring."}, {"id": "specs_2026_06_01_lumen_design_vite_proxy_token", "label": "Server-side token injection via dev-server proxy", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The Vite proxy reads the PAT from .env server-side and attaches the auth header on every proxied request, so the token never ships in client bundles or browser storage."}, {"id": "specs_2026_06_01_lumen_design_query_cache_split", "label": "TanStack Query + graphql-request split", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "TanStack Query owns caching/refetch/pagination/state; graphql-request only sends the query; codegen provides typed documents. Apollo/urql rejected because their normalized caches would duplicate Vue Query."}], "edges": [{"source": "specs_2026_06_01_lumen_design_vite_proxy_token", "target": "plans_2026_06_10_host_server_health_observe_classification", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_01_lumen_design_doc", "target": "specs_2026_06_01_lumen_design_lumen_app", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_01_lumen_design_doc", "target": "specs_2026_06_01_lumen_design_vite_proxy_token", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_01_lumen_design_doc", "target": "specs_2026_06_01_lumen_design_query_cache_split", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_01_lumen_design_vite_proxy_token", "target": "specs_2026_06_01_lumen_design_lumen_app", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_01_lumen_design_query_cache_split", "target": "specs_2026_06_01_lumen_design_lumen_app", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-lumen-design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}