{"nodes": [{"id": "plans_2026_06_10_mcp_server_gitlab_doc", "label": "Plan: MCP Server (GitLab)", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_10_mcp_server_gitlab_mcp_server", "label": "In-process MCP server (Bun)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Opt-in, localhost-only (127.0.0.1), bearer-authenticated Bun.serve in the main process exposing GitLab tools to external agents; self-contained src/bun/mcp/ module."}, {"id": "plans_2026_06_10_mcp_server_gitlab_stateless_transport", "label": "Stateless streamable-HTTP transport per request", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The SDK's WebStandardStreamableHTTPServerTransport verified to run under Bun in stateless JSON mode (sessionIdGenerator: undefined, enableJsonResponse: true) \u2014 a fresh McpServer + transport per request; Web-standard Request/Response makes the handler testable under Vitest without Bun.serve."}, {"id": "plans_2026_06_10_mcp_server_gitlab_mcptool_registry", "label": "McpTool registry", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tools are plain objects { name, description, inputSchema (Zod raw shape), handler } collected in a registry and registered with the SDK, which auto-converts to JSON Schema and validates tools/call args."}, {"id": "plans_2026_06_10_mcp_server_gitlab_gitlab_tools", "label": "GitLab MCP tool suites", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Issues/MRs/labels-milestones/users-search tools hand-write GraphQL (no codegen) and call the existing gitlabGraphql/gitlabRest clients. Verified GitLab quirks: iid args are String; CreateIssueInput.labels takes title strings but most label/assignee/milestone inputs need GlobalIDs; approve/unapprove are REST-only; no cross-project search."}], "edges": [{"source": "plans_2026_06_10_mcp_server_gitlab_doc", "target": "plans_2026_06_10_mcp_server_gitlab_mcp_server", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_mcp_server_gitlab_doc", "target": "plans_2026_06_10_mcp_server_gitlab_stateless_transport", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_mcp_server_gitlab_doc", "target": "plans_2026_06_10_mcp_server_gitlab_mcptool_registry", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_mcp_server_gitlab_doc", "target": "plans_2026_06_10_mcp_server_gitlab_gitlab_tools", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-mcp-server-gitlab.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_mcp_server_gitlab_mcp_server", "target": "plans_2026_06_10_mcp_server_gitlab_stateless_transport", "relation": "references", "confidence": "EXTRACTED