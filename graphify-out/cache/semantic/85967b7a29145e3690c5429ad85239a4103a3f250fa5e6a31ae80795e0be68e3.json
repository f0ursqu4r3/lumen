{"nodes": [{"id": "plans_2026_06_05_open_issue_in_native_window_doc", "label": "Plan: Open Issues in Native Window", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_05_open_issue_in_native_window_issuewindowurl", "label": "issueWindowUrl URL builder", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure, testable URL builder mirroring startUrl.ts; route lives in the hash because the app uses createWebHashHistory, and ?window=1 marks a focused single-issue window."}, {"id": "plans_2026_06_05_open_issue_in_native_window_openissuewindow", "label": "openIssueWindow RPC handler", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One native window per issue keyed by fullPath#iid so re-expanding focuses the existing window instead of spawning a duplicate; per-window close events keep the registry accurate; windows cascade to avoid perfect overlap."}, {"id": "plans_2026_06_05_open_issue_in_native_window_buildrpc", "label": "buildRpc per-window RPC factory", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each native window needs its own RPC bridge, so the inline rpc const is refactored into a factory producing a fresh config per window."}, {"id": "plans_2026_06_05_open_issue_in_native_window_windowed_mode", "label": "Windowed mode (?window=1)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The router maps ?window=1 to a windowed prop (rather than useRoute) because tests fully mock vue-router; windowed suppresses the back-to-list arrow in a standalone native window."}], "edges": [{"source": "plans_2026_06_05_open_issue_in_native_window_doc", "target": "plans_2026_06_05_open_issue_in_native_window_issuewindowurl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_05_open_issue_in_native_window_doc", "target": "plans_2026_06_05_open_issue_in_native_window_openissuewindow", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_05_open_issue_in_native_window_doc", "target": "plans_2026_06_05_open_issue_in_native_window_buildrpc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_05_open_issue_in_native_window_doc", "target": "plans_2026_06_05_open_issue_in_native_window_windowed_mode", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-05-open-issue-in-native-window.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_05_open_issue_in_native_window_openissuewindow", "target": "plans_2026_06_05_open_issue_in_native_window_issuewindowurl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/202