{"nodes": [{"id": "specs_2026_06_04_settings_dialog_design", "label": "Settings Dialog Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_04_settings_dialog_design_settingsdialog", "label": "SettingsDialog Modal", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Centered modal dialog chosen over a settings page because the app has no persistent chrome to navigate from and the dialog keeps the user in their work context. No invented preference rows \u2014 all persisted state is per-project and the theme is deliberately fixed."}, {"id": "specs_2026_06_04_settings_dialog_design_usesettings", "label": "useSettings Singleton + Menu Bridge", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "macOS app menu is the idiomatic entry point since the shell renders no persistent header; host\u2192webview bridge via executeJavascript dispatching the lumen:open-settings CustomEvent, with a webview \u2318, onKeyStroke fallback in case the menu bridge regresses."}, {"id": "specs_2026_06_04_settings_dialog_design_usegitlabconnect", "label": "useGitlabConnect Shared Connect Logic", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extracted from onboarding so the swap-token form is not a copy of onboarding: the composable owns the probe; callers decide the success side-effect (navigate vs toast)."}, {"id": "specs_2026_06_04_settings_dialog_design_clearpersistedcache", "label": "clearPersistedCache Helper", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Explicit key on createSyncStoragePersister (lumen:query-cache) so the same constant is used to write and to clear \u2014 don't rely on the library default key string."}], "edges": [{"source": "specs_2026_06_04_settings_dialog_design", "target": "specs_2026_06_04_settings_dialog_design_settingsdialog", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_settings_dialog_design", "target": "specs_2026_06_04_settings_dialog_design_usesettings", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_settings_dialog_design", "target": "specs_2026_06_04_settings_dialog_design_usegitlabconnect", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_settings_dialog_design", "target": "specs_2026_06_04_settings_dialog_design_clearpersistedcache", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-04-settings-dialog-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_04_settings_dialog_design_settingsdialog", "target": "specs_2026_06_04_settings_dialog_design_usegitlabconnect", "relation": "references", "confidence": "EXTRACTED", "confidence_score"