{"nodes": [{"id": "plans_2026_06_10_host_server_health_doc", "label": "Plan: Host-Owned Server Health", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_10_host_server_health_serverhealth_machine", "label": "serverHealth host state machine", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GitLab reachability becomes a single host-owned state machine (ok | down | expired) with one recovery loop and countdown, mirrored by every window \u2014 replacing per-window detection/recovery duplication. Probe fn and broadcaster are injected for testability."}, {"id": "plans_2026_06_10_host_server_health_observe_classification", "label": "observe() request-outcome feed", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The host's gitlabGraphql/gitlabRest are the request choke point (every GitLab request flows through them), so each result's classification feeds observe(); classifyStatus mirrors the old probeServer rules including bodyless-403 = edge/LB block = down."}, {"id": "plans_2026_06_10_host_server_health_window_registry_broadcast", "label": "Window registry + lumen:server-health broadcast", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "There was no unified window registry (main win, issueWindows Map, settingsWindow tracked separately); a new registry lets state changes broadcast lumen:server-health to every window."}, {"id": "plans_2026_06_10_host_server_health_installserverhealth", "label": "installServerHealth webview mirror", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Thin replacement for installAuthWatch/probeServer/useServerRecovery: mirrors host state into sessionState and refetches this window's queries on recovery; banner/overlay become pure displays."}, {"id": "plans_2026_06_10_host_server_health_confirm_then_latch", "label": "Confirm-then-latch auth rule", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A single transient 401 must NOT expire the session: an auth observation is confirmed by a probe before latching expired; if the probe is clean the state stays ok."}], "edges": [{"source": "plans_2026_06_10_host_server_health_doc", "target": "plans_2026_06_10_host_server_health_serverhealth_machine", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_host_server_health_doc", "target": "plans_2026_06_10_host_server_health_observe_classification", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_10_host_server_health_doc", "target": "plans_2026_06_10_host_server_health_window_registry_broadcast", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-10-host-server-health.md", "source_location": null, "weight": 1.0}, {"sour