{"nodes": [{"id": "specs_2026_06_09_unified_app_shell_design", "label": "Unified App Shell Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_09_unified_app_shell_design_appshell", "label": "AppShell Persistent Chrome", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces ad-hoc duplicated per-view headers with one persistent shell: slim global icon rail + contextual top bar + standard content container. Context derivation needs no new store \u2014 the top bar and tabs are pure functions of the route. Views feed affordances into named shell slots."}, {"id": "specs_2026_06_09_unified_app_shell_design_chrome_off_rule", "label": "Chrome-Off Rule", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "connect, issues-window, and any ?window=1 route render the view WITHOUT the shell in the same minimal main container as today, so every native-window flow is untouched. Static cases via route.meta.chrome === false; the window query checked live."}, {"id": "specs_2026_06_09_unified_app_shell_design_projecttabnav", "label": "ProjectTabNav Component", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Issues/MRs/Pipelines tabs for a fullPath; carries the running-pipeline adornment that previously lived in the deleted per-view headers."}, {"id": "specs_2026_06_09_unified_app_shell_design_viewcontainer", "label": "ViewContainer Width Container", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Width stops being re-decided per view: default max-w-5xl with a small width-prop enum (wide for board/picker, narrow for My Work); every view's ad-hoc outer wrapper is deleted."}], "edges": [{"source": "specs_2026_06_09_unified_app_shell_design", "target": "specs_2026_06_09_unified_app_shell_design_appshell", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_unified_app_shell_design", "target": "specs_2026_06_09_unified_app_shell_design_chrome_off_rule", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_unified_app_shell_design", "target": "specs_2026_06_09_unified_app_shell_design_projecttabnav", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_unified_app_shell_design", "target": "specs_2026_06_09_unified_app_shell_design_viewcontainer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-unified-app-shell-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_09_unified_app_shell_design_appshell", "target": "specs_2026_06_09_unified_app_shell_design_chrome_off_rule", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": 