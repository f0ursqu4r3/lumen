{"nodes": [{"id": "specs_2026_06_05_open_issue_in_native_window_design", "label": "Open Issue in Native Window Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_05_open_issue_in_native_window_design_openissuewindow", "label": "openIssueWindow RPC + Window Registry", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One window per issue: a module-level Map keyed by fullPath#iid means re-expanding an already-open issue focuses its existing window rather than spawning a duplicate; frame cascades by registry size so stacked windows don't fully overlap. Each window gets a fresh buildRpc() instance."}, {"id": "specs_2026_06_05_open_issue_in_native_window_design_issuewindowurl", "label": "issueWindowUrl URL Builder", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure and testable, matching the existing startUrl.ts/menu.ts testable-helper pattern; works for both HMR and bundled views:// bases."}, {"id": "specs_2026_06_05_open_issue_in_native_window_design_windowed_mode", "label": "IssueDetail Windowed Mode (?window=1)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The issue window is a focused single-issue view, so the back-to-list arrow is suppressed; useTitle and the unsaved-edits route-leave guard stay enabled \u2014 both correct for a standalone window. Each window cold-boots the whole SPA with no shared query cache, acceptable for a daily-driver desktop app."}], "edges": [{"source": "specs_2026_06_05_open_issue_in_native_window_design", "target": "specs_2026_06_05_open_issue_in_native_window_design_openissuewindow", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_open_issue_in_native_window_design", "target": "specs_2026_06_05_open_issue_in_native_window_design_issuewindowurl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_open_issue_in_native_window_design", "target": "specs_2026_06_05_open_issue_in_native_window_design_windowed_mode", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_open_issue_in_native_window_design_openissuewindow", "target": "specs_2026_06_05_open_issue_in_native_window_design_issuewindowurl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_open_issue_in_native_window_design_openissuewindow", "target": "specs_2026_06_05_open_issue_in_native_window_design_windowed_mode", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-open-issue-in-native-window-design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}