{"nodes": [{"id": "specs_2026_06_02_issue_composer_design_doc", "label": "Spec: Issue Composer", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-02-issue-composer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_02_issue_composer_design_issuecomposer", "label": "IssueComposer slide-over", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-composer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces the always-visible title-only quick-create bar with an on-demand right-side Sheet (header button, C key, empty-state button) offering full-fidelity creation with progressive disclosure; deliberately mirrors IssueDrawer so reading and creating feel like one family of surfaces."}, {"id": "specs_2026_06_02_issue_composer_design_useprojectmembers", "label": "useProjectMembers composable", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-issue-composer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The app had no users query (assignees only known from loaded issues); mirrors useProjectLabels with projectMembers query, null filtering, normalizeError, ~5min staleTime."}, {"id": "specs_2026_06_02_issue_composer_design_flash_highlight", "label": "Flash-highlight confirmation", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-02-issue-composer-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Preserves the quiet no-toast feel: after the invalidated list refetches, briefly highlight the row whose iid matches the newly created issue, then fade \u2014 small transient highlightIid state on IssueList."}], "edges": [{"source": "specs_2026_06_02_issue_compose