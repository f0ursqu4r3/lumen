{"nodes": [{"id": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design", "label": "Issue Multi-Select Bulk + Combined Window Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_useissueselection", "label": "useIssueSelection Composable", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ephemeral selection state shared via provide/inject (Symbol key) to avoid prop-threading through v-for; the Set survives filtering/sort/pagination; rows/cards fall back to a no-op state when not provided so isolated tests render unchanged."}, {"id": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_bulkactionbar", "label": "BulkActionBar Component", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The bar holds no mutation logic \u2014 it emits intent that IssueList or the bulk composable handles. Selection is kept after a successful bulk action so the user can chain actions."}, {"id": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_usebulkissueactions", "label": "useBulkIssueActions Composable", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A bulk apply is N independent mutations reusing the existing optimistic per-issue mutations (useRetagIssue/useReassignIssue/useSetIssueStatus) via Promise.allSettled; failures are surfaced in a result toast but do not roll back successes. Confirm dialog first."}, {"id": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_multiissuewindow", "label": "MultiIssueWindow Pager View", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single issue at a time behind a '\u2039 X of N \u203a' pager, each page fully editable by reusing IssueDetail in windowed mode keyed by current iid so paging remounts cleanly; paging away from a dirty page prompts to discard. Spawns a new window each time (no dedupe), URL built by issuesWindowUrl."}], "edges": [{"source": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design", "target": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_useissueselection", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design", "target": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_bulkactionbar", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-05-issue-multiselect-bulk-and-combined-window-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design", "target": "specs_2026_06_05_issue_multiselect_bulk_and_combined_window_design_usebulkissueactions", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/supe