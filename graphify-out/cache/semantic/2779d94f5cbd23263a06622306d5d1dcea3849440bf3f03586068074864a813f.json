{"nodes": [{"id": "plans_2026_06_04_electrobun_port_plan", "label": "Electrobun Port Implementation Plan", "file_type": "document", "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_2026_06_04_electrobun_port_rpc_contract", "label": "LumenRPC Typed Contract (rpcContract.ts)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single source of truth for the RPC surface (gitlabGraphql, gitlabRest, gitlabAsset, config CRUD), imported by both Bun handlers and the view wrapper. Electrobun's own view-side generics are loose, so app code stays typed by funneling every call through one typed wrapper that internally casts to any \u2014 do not fight the framework generics."}, {"id": "plans_2026_06_04_electrobun_port_fetch_shim", "label": "RPC Fetch Shim for graphql-request", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "src/gitlab/client.ts keeps graphql-request but swaps its transport for the gitlabGraphql RPC, replacing the old /gitlab Vite proxy; images load as blob URLs fetched through gitlabAsset RPC."}, {"id": "plans_2026_06_04_electrobun_port_persisted_cache", "label": "Disk-Persisted vue-query Cache", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A persisted vue-query cache (query-persist-client-core, lib/persist.ts with persister + buster) gives instant-offline render on launch."}, {"id": "plans_2026_06_04_electrobun_port_host_config", "label": "App-Support Host Config (src/bun/config.ts)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The Bun main process reads the token from an app-support config file with first-run env import; the token never enters the webview \u2014 handlers attach it host-side with TLS verification relaxed for internal CAs."}], "edges": [{"source": "plans_2026_06_04_electrobun_port_plan", "target": "plans_2026_06_04_electrobun_port_rpc_contract", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_04_electrobun_port_plan", "target": "plans_2026_06_04_electrobun_port_fetch_shim", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_04_electrobun_port_plan", "target": "plans_2026_06_04_electrobun_port_persisted_cache", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_04_electrobun_port_plan", "target": "plans_2026_06_04_electrobun_port_host_config", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "weight": 1.0}, {"source": "plans_2026_06_04_electrobun_port_fetch_shim", "target": "plans_2026_06_04_electrobun_port_rpc_contract", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-06-04-electrobun-port.md", "source_location": null, "weight": 1.0}], "h