{"nodes": [{"id": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_doc", "label": "Spec: Comments-in-Save, Grouped Labels, Collapsible Scratchpad", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_comments_in_save", "label": "Comments folded into Save/Cancel", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A pending comment alone marks the issue dirty; the comment is a note (not an issue field) so it stays out of the pure IssueDraft/diffIssueEdit and is owned by the orchestration composable \u2014 yielding a single dirty/save/footer/guard."}, {"id": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_labelgroups", "label": "labelGroups (groupLabelsByScope + toggleScoped)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Groups labels by scope:: prefix with preferred scopes first and unscoped 'Other' last; toggleScoped enforces scoped-label exclusivity (one value per scope) for add-label, while the filter keeps plain multi-toggle since filters can span scopes."}, {"id": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_labelgroupmenu", "label": "LabelGroupMenu nested flyout", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_collapsible_scratchpad", "label": "Collapsible scratchpad", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default collapsed with a content marker; open/closed state remembered per issue in localStorage; Textarea v-show-hidden to preserve value/focus."}], "edges": [{"source": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_doc", "target": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_comments_in_save", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_doc", "target": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_labelgroups", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_doc", "target": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_labelgroupmenu", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_doc", "target": "specs_2026_06_02_comments_grouped_labels_scratchpad_design_collapsible_scratchpad", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-02-comments-grouped-labels-scratchpad-design.md", "source_location"