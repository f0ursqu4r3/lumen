{"nodes": [{"id": "specs_2026_06_08_command_palette_navigator_design", "label": "Command Palette Navigator Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-08-command-palette-navigator-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_08_command_palette_navigator_design_palette_sources", "label": "Palette Command Sources (sources.ts)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-command-palette-navigator-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The single ~120-line commands computed already mixes route logic, project search, and #-jump; adding issue search + views inline would make it unmaintainable. Typed pure source builders with PaletteContext passed in (not reached for) give clean boundaries and test seams."}, {"id": "specs_2026_06_08_command_palette_navigator_design_usepalettecommands", "label": "usePaletteCommands Merger", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-command-palette-navigator-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Merges sources into a grouped, ranked list with fixed group order; flat keyboard nav walks a single flattened index spanning all groups."}, {"id": "specs_2026_06_08_command_palette_navigator_design_usepaletteissuesearch", "label": "usePaletteIssueSearch Debounced Search", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-command-palette-navigator-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Follows the manual-type pattern of useIssue.ts (inline template-literal document + hand-written result type) so typecheck stays green without running bun codegen. Debounced ~200ms, gate