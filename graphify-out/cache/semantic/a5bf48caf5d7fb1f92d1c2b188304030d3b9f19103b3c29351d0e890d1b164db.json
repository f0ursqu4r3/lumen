{"nodes": [{"id": "specs_2026_06_08_merge_requests_browse_triage_design", "label": "Merge Requests Browse + Triage Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_08_merge_requests_browse_triage_design_merge_requests_module", "label": "features/merge_requests Module", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mirrors the proven features/issues patterns but lean \u2014 answers the daily 'what MRs need my attention' loop without the heavy diff-review machinery. Manual-typed GraphQL (no codegen); the MR detail discussion shape matches useIssue so IssueDiscussion rendering is reused as-is. labelName used because the labels arg is deprecated upstream."}, {"id": "specs_2026_06_08_merge_requests_browse_triage_design_usesavedviews_generalized", "label": "Generalized useSavedViews (namespace + keys)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The one shared lift \u2014 the only change to existing stable code: parameterize storage namespace + filter keys so issue and MR saved views live in separate localStorage namespaces while preserving existing issue behavior and tests."}, {"id": "specs_2026_06_08_merge_requests_browse_triage_design_usemrfilters", "label": "useMrFilters Composable", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mirrors useIssueFilters: URL-encoded reactive slice, restored from localStorage per project; the pure slice \u2192 GraphQL-args mapping lives in lib/mrView.ts so it is unit-testable without mounting."}, {"id": "specs_2026_06_08_merge_requests_browse_triage_design_mr_palette_integration", "label": "MR Palette Integration (!iid jump + MR group)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses the !iid convention to avoid colliding with the issue #123 jump; reuses the issue search's gcTime:0 + persist.ts dehydrate-exclusion treatment."}], "edges": [{"source": "specs_2026_06_08_merge_requests_browse_triage_design", "target": "specs_2026_06_08_merge_requests_browse_triage_design_merge_requests_module", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_08_merge_requests_browse_triage_design", "target": "specs_2026_06_08_merge_requests_browse_triage_design_usesavedviews_generalized", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_08_merge_requests_browse_triage_design", "target": "specs_2026_06_08_merge_requests_browse_triage_design_usemrfilters", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-08-merge-requests-browse-triage-design.md", "source_location": null, "weight": 1.0}, {"source": "specs_2026_06_08_merge_requests_browse_triage_design", "target": "specs_2026_06_08_merge_requests_browse_triage_design_mr_palette_integration