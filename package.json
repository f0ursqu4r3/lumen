{
  "name": "lumen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electrobun build",
    "production": "bash scripts/build-production.sh",
    "dist": "vue-tsc --noEmit && vite build && electrobun build --env=canary",
    "sign-cert": "bash scripts/make-signing-cert.sh",
    "app:dev": "vite build && electrobun dev",
    "app:hmr": "vite & VITE_PID=$!; trap 'kill $VITE_PID 2>/dev/null' EXIT INT TERM; until nc -z localhost ${LUMEN_DEV_PORT:-5273}; do sleep 0.2; done; LUMEN_HMR=1 electrobun dev",
    "preview": "vite preview",
    "codegen": "NODE_TLS_REJECT_UNAUTHORIZED=0 graphql-codegen --config codegen.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@lucide/vue": "^1.17.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/query-persist-client-core": "5.100.14",
    "@tanstack/query-sync-storage-persister": "5.100.14",
    "@tanstack/vue-query": "^5.62.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.7",
    "electrobun": "^1.18.1",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "marked": "^18.0.4",
    "reka-ui": "^2.9.9",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.8.1"
  }
}
