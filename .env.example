# Copy to .env (or .env.development) and fill in. Read by Vite (proxy) and codegen.
GITLAB_URL=https://gitlab.example-corp.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxx   # Personal Access Token, scope: api

# NOTE: this tool disables TLS verification for the upstream GitLab
# (vite.config.ts `secure: false` + the codegen script's NODE_TLS_REJECT_UNAUTHORIZED=0)
# to accommodate internal-CA certs. It is local-dev-only and never affects a
# production build. If you point GITLAB_URL at a publicly-trusted host, set
# `secure: true` and drop NODE_TLS_REJECT_UNAUTHORIZED.
